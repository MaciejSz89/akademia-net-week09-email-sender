@using EmailSenderAspNetMvc.Models.Domains

@model List<EmailMessageReceiver>



@for (int i = 0; i < Model.Count; i++)
{



<div class="row email-receiver">
    @Html.HiddenFor(x => x[i].EmailAddress.Id, new { @class = "email-receiver-id" })
    <div class="col-4">
        @Html.TextBoxFor(x => x[i].EmailAddress.DisplayName, new
        {
            @class = "form-control email-receiver-display-name mb-2",
            onfocusout = "updateValue($(this), this.value)",
            placeholder = "Nazwa odbiorcy"
        })
    </div>
    <div class="col-6">
        @Html.TextBoxFor(x => x[i].EmailAddress.Address, new
        {
            @class = "form-control email-receiver-address mb-2",
            onfocusout = "updateValue($(this), this.value)",
            placeholder = "Email odbiorcy"
        })
    </div>
    <div class="col-2">
        <button type="button"
                class="btn btn-danger"
                onclick='deleteEmailReceiver($(this).parents(".email-receiver"))'>
            Usuń
        </button>
    </div>

</div>

}
<div>
    <button class="btn btn-secondary btn-sm"
            type="button"
            onclick='addEmailReceiver($(".email-receiver"))'>
        Dodaj odbiorcę
    </button>
</div>

